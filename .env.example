# ============================================================
# Sentinel — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# .env is listed in .gitignore and will NEVER be committed.
# Never paste credentials directly into config.yaml or source code.
# ============================================================

# Claude API key (required for Phase 2 LLM log analysis)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Dashboard API key — set a long random string to protect the REST API.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SENTINEL_API_KEY=your_random_api_key_here

# Email alerting (only needed if alerting.email.enabled = true in config.yaml)
# For Gmail: enable 2FA then create an App Password at myaccount.google.com/apppasswords
SENTINEL_EMAIL_SENDER=your_email@gmail.com
SENTINEL_EMAIL_PASSWORD=your_app_password_here
SENTINEL_EMAIL_RECIPIENT=alerts_recipient@example.com

# Slack alerting (only needed if alerting.slack.enabled = true)
# Create an incoming webhook at: api.slack.com/messaging/webhooks
SENTINEL_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Generic webhook alerting (Discord, custom dashboard, etc.)
SENTINEL_WEBHOOK_URL=https://your-webhook-endpoint.example.com/alert
